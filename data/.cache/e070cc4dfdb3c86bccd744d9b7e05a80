		<title>Tesla plans to use Intel 14A chips for Terafab project</title>
		<link>https://techwireasia.com/2026/04/tesla-intel-14a-chips-terafab/</link>
		
		<dc:creator><![CDATA[Muhammad Zulhusni]]></dc:creator>
		<pubDate>Thu, 23 Apr 2026 09:00:21 +0000</pubDate>
