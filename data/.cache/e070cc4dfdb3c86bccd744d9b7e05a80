		<title>MATCH Act passes first hurdle–targeting semiconductor tools, not just chips</title>
		<link>https://techwireasia.com/2026/04/match-act-semiconductor-export-controls-congress-advances/</link>
		
		<dc:creator><![CDATA[Dashveenjit Kaur]]></dc:creator>
		<pubDate>Fri, 24 Apr 2026 10:30:06 +0000</pubDate>
				<category><![CDATA[Asia Pacific Focus]]></category>
		<category><![CDATA[Business Intelligence]]></category>
		<category><![CDATA[China]]></category>
		<category><![CDATA[Compliance, Regulations & Governance]]></category>
		<category><![CDATA[asml]]></category>
		<category><![CDATA[China semiconductors]]></category>
		<category><![CDATA[chipmaking equipment]]></category>
		<category><![CDATA[CXMT]]></category>
		<category><![CDATA[DUV lithography]]></category>
		<category><![CDATA[House Foreign Affairs Committee]]></category>
		<category><![CDATA[MATCH Act]]></category>
		<category><![CDATA[Micron]]></category>
		<category><![CDATA[semiconductor export controls]]></category>
