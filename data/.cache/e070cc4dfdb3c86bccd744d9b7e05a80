		<title>DeepSeek V4 points to growing use of Huawei chips in AI models</title>
		<link>https://techwireasia.com/2026/04/deepseek-v4-points-to-growing-use-of-huawei-chips-in-ai-models/</link>
		
		<dc:creator><![CDATA[Muhammad Zulhusni]]></dc:creator>
		<pubDate>Mon, 06 Apr 2026 09:00:09 +0000</pubDate>
				<category><![CDATA[AI & Intelligence]]></category>
