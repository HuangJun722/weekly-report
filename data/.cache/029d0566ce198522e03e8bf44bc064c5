		<title>Everything Google announced at the Android Show: I/O Edition 2026</title>
		<link>https://techcabal.com/2026/05/12/everything-google-announced-at-the-android-show-i-o-edition/</link>
		
		<dc:creator><![CDATA[Fancy Goodman]]></dc:creator>
		<pubDate>Tue, 12 May 2026 20:52:56 +0000</pubDate>
				<category><![CDATA[Consumer Tech]]></category>
		<category><![CDATA[Android 17]]></category>
