                <span class="tc-bar-value" style="font-size: 0.875rem; font-weight: 600; color: #4A5568;">${display2025}</span>
              </div>

              <div class="tc-bar-row" style="margin-bottom: 0;">
                <div class="tc-bar-track-wrapper" style="height: 24px;">
                  <div style="width: 0%; background: #EA2D2E; height: 100%; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 4px;" data-width="${pct2026}%"></div>
                </div>
                <span class="tc-bar-value" style="font-size: 0.875rem; font-weight: 700; color: #151515;">${display2026}</span>
