<div style="width: 100%; padding: 8px; height:47px; font-size: 10px;font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-weight: 700; background-color: #fcf8fa; border-radius: 4px; box-sizing:border-box; display: table;">
