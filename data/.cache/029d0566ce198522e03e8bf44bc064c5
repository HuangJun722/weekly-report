      const container = document.getElementById('tc-issuance-body');
      container.innerHTML = '';
      
      const maxTotal = Math.max(...data.map(d => d.y22 + d.y23 + d.y24));

      data.forEach((d, i) => {
        const total = d.y22 + d.y23 + d.y24;
        const width = Math.max((total / maxTotal) * 100, 2); 
