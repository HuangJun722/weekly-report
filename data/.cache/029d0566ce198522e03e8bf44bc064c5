    <script>
        // Formats the input field with commas as the user types
        function handleInput(event) {
            let inputField = event.target;
            
            // Strip out all non-numeric characters except the decimal point
            let unformatted = inputField.value.replace(/[^0-9.]/g, '');
            
            // Split by decimal to ensure we only format the integer part
            let parts = unformatted.split('.');
            parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            
            // Rejoin and set the value
            inputField.value = parts.join('.');
            
            // Trigger calculation
            calculateFees();
        }

        function calculateFees() {
            // Get inputs and remove commas for math
            const rawInvestment = document.getElementById('tc-investment').value.replace(/,/g, '');
            const investment = parseFloat(rawInvestment);
            const returnRate = parseFloat(document.getElementById('tc-return').value);
            
            // Update slider label
            document.getElementById('tc-return-label').innerText = returnRate.toFixed(1) + '%';

            if(isNaN(investment) || investment < 0) return;

            // Math based on the article's context
            const estimatedFeeRate = 0.015; 
            const fee = investment * estimatedFeeRate;
            const grossReturn = investment * (returnRate / 100);
            const netProfit = grossReturn - fee;
            const totalBalance = investment + netProfit;

            // Formatter for outputs (commas + 2 decimal places)
            const formatMoney = (amount) => {
                return '₦' + amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            };

            // Display outputs
            document.getElementById('tc-fee-output').innerText = formatMoney(fee);
            document.getElementById('tc-profit-output').innerText = formatMoney(netProfit > 0 ? netProfit : 0);
            document.getElementById('tc-total-output').innerText = formatMoney(totalBalance);
            
            // Update the visual proportion bar
            const totalGained = fee + (netProfit > 0 ? netProfit : 0);
            let profitPercent = 0;
            let feePercent = 0;

            if (totalGained > 0) {
                feePercent = (fee / totalGained) * 100;
                profitPercent = 100 - feePercent;
            }

            document.getElementById('tc-bar-profit').style.width = profitPercent + '%';
            document.getElementById('tc-bar-fee').style.width = feePercent + '%';
        }

        // Initialize on load
        document.addEventListener("DOMContentLoaded", calculateFees);
    </script>
