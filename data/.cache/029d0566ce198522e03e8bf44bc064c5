		<title>Quick Fire 🔥 with Michael Emeeka</title>
		<link>https://techcabal.com/2026/05/01/quick-fire-%f0%9f%94%a5-with-michael-emeeka/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Fri, 01 May 2026 08:18:58 +0000</pubDate>
				<category><![CDATA[Quick Fire]]></category>
		<category><![CDATA[Africa]]></category>
		<category><![CDATA[Crypto]]></category>
