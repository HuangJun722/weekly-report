            tooltip.style.opacity = '1';
            tooltip.innerHTML = `<strong>${pctOfTotal}% of Workforce</strong>${band.count.toLocaleString()} staff members earn<br>${band.label} annually.`;
          });
          
          row.addEventListener('pointermove', (e) => {
            const wrapperRect = wrapper.getBoundingClientRect();
            
            // Calculate initial positions
            let left = e.clientX - wrapperRect.left + 15;
            let top = e.clientY - wrapperRect.top + 15;
            
            // Mobile bounds checking: prevent tooltip from overflowing the widget edges
            const tooltipWidth = tooltip.offsetWidth || 200;
            if (left + tooltipWidth > wrapperRect.width) {
              left = e.clientX - wrapperRect.left - tooltipWidth - 15;
            }
            // Ensure tooltip doesn't bleed off the left edge
            if (left < 10) {
                left = 10;
            }
            
            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
          });

          row.addEventListener('pointerleave', () => {
            tooltip.style.opacity = '0';
          });

          chartContainer.appendChild(row);

          // Animate bars in
          setTimeout(() => {
            const fill = row.querySelector('.tc-bar-fill');
            fill.style.width = fill.getAttribute('data-width');
          }, 50 + (index * 30));
        });
      };

      renderChart();

      // Button Logic
      const btnHierarchy = document.getElementById('sort-hierarchy');
      const btnDensity = document.getElementById('sort-density');

      btnHierarchy.addEventListener('click', () => {
        if (currentSort === 'hierarchy') return;
        currentSort = 'hierarchy';
        btnHierarchy.classList.add('active');
        btnDensity.classList.remove('active');
        renderChart();
      });

      btnDensity.addEventListener('click', () => {
        if (currentSort === 'density') return;
        currentSort = 'density';
        btnDensity.classList.add('active');
        btnHierarchy.classList.remove('active');
        renderChart();
      });

      // Hide tooltip when leaving wrapper or lifting finger
      wrapper.addEventListener('pointerleave', () => {
        tooltip.style.opacity = '0';
      });
      document.addEventListener('touchstart', (e) => {
        if (!wrapper.contains(e.target)) {
            tooltip.style.opacity = '0';
        }
      });

    })();
  </script>
