	<item>
		<title>He started building in military-era Nigeria. Now he builds AI HR software.</title>
		<link>https://techcabal.com/2026/05/19/nigerias-talpro-software-enters-the-ai-hr-race/</link>
		
		<dc:creator><![CDATA[Frank Eleanya]]></dc:creator>
		<pubDate>Tue, 19 May 2026 16:59:58 +0000</pubDate>
				<category><![CDATA[Features]]></category>
		<category><![CDATA[Africa]]></category>
		<category><![CDATA[AI agents]]></category>
