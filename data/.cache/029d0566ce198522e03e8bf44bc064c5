		<title>AGL taps REasy to launch China-Cameroon shipping service for SMEs</title>
		<link>https://techcabal.com/2026/05/15/agl-taps-reasy-to-launch-china-cameroon-shipping-service-for-smes/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Fri, 15 May 2026 07:37:23 +0000</pubDate>
