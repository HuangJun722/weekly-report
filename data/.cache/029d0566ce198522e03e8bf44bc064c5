      </div>
      <div class="tc-unit-card" style="border-left: 4px solid #A0AEC0;">
        <div class="tc-card-label">Cash Held</div>
        <div class="tc-card-value" id="tc-val-cash">₦0.0</div>
      </div>
    </div>

    <div class="tc-arrow-right">→</div>
    <div class="tc-arrow-down">↓</div>

