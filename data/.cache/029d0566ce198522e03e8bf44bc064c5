		<title>MTN Nigeria shareholders to vote on fintech spin-off on Thursday</title>
		<link>https://techcabal.com/2026/04/29/mtn-nigeria-shareholders-to-vote-on-fintech-spin-off/</link>
		
		<dc:creator><![CDATA[Frank Eleanya]]></dc:creator>
		<pubDate>Wed, 29 Apr 2026 09:17:30 +0000</pubDate>
				<category><![CDATA[Telecoms]]></category>
		<category><![CDATA[Africa]]></category>
		<category><![CDATA[Fintech]]></category>
		<category><![CDATA[MTN]]></category>
		<category><![CDATA[mtn momo]]></category>
		<category><![CDATA[Nigeria]]></category>
