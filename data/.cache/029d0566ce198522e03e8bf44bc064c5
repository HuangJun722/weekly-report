		<title>MTN awards Nigeria CEO Karl Toriola $335,000 in performance shares</title>
		<link>https://techcabal.com/2026/04/08/mtn-nigeria-ceo-group-share-award/</link>
		
		<dc:creator><![CDATA[Frank Eleanya]]></dc:creator>
