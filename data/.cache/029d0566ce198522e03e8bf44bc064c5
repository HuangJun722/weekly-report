                <div style="width:100%; background-color: transparent; box-sizing:border-box;">
                    <h3 style="width:100%; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:16px;margin:0;padding-bottom:16px;font-weight:700;color:#28121F;line-height:20px;text-transform:capitalize;letter-spacing:-0.32px;text-align:left;box-sizing:border-box;">Kenya freezes accounts of Binance users</h3>
                    <div style="font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-weight: 400;font-size:16px;line-height:25.6px;margin:0;padding-bottom:16px;box-sizing:border-box;">
