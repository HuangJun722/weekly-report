<div class="tc-zenith-wrapper" id="tc-zenith-app" aria-label="Interactive Salary Distribution">
  
  <div class="tc-zenith-tooltip" id="tc-zenith-tooltip"></div>

  <div class="tc-zenith-header">
    <div class="tc-zenith-header-content">
      <div>
        <span class="tc-zenith-tag">Raw Data</span>
        <h3 style="margin: 0 0 8px 0; font-size: 1.4rem; font-weight: 800; line-height: 1.3;">
          The 7 Tiers of Zenith Bank&#8217;s Payroll
        </h3>
        <p style="margin: 0; font-size: 0.95rem; color: #4A4A4A; line-height: 1.6;">
          A granular look at the exact annual salary bands of all 10,397 Zenith Bank employees, extracted directly from their 2025 audited financial statements.
        </p>
      </div>
      <div class="tc-zenith-stat-box">
        <span style="display: block; font-size: 0.65rem; color: #717171; text-transform: uppercase; font-weight: 600;">Reported Staff</span>
        <strong style="font-size: 1.2rem; color: #151515;">10,397</strong>
      </div>
    </div>
  </div>

  <div class="tc-zenith-controls">
    <div style="font-size: 0.8rem; font-weight: 600; color: #717171; text-transform: uppercase;">Sort Data By:</div>
    <div class="tc-zenith-sort-group">
      <button class="tc-zenith-sort-btn active" id="zenith-sort-hierarchy">Salary Tier (High to Low)</button>
      <button class="tc-zenith-sort-btn" id="zenith-sort-density">Headcount (Largest Group)</button>
    </div>
  </div>

  <div class="tc-zenith-chart-area">
    <div id="tc-zenith-chart-render" style="display: flex; flex-direction: column;">
      </div>

    <div style="margin-top: 32px; padding: 16px 20px; background: #FFF9F9; border-left: 4px solid #EA2D2E; border-radius: 4px;">
      <strong style="display: block; font-size: 0.8rem; color: #EA2D2E; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">The TechCabal Takeaway</strong>
      <p style="margin: 0; font-size: 0.9rem; color: #151515; line-height: 1.5;">
        Toggle to <strong>&#8220;Headcount&#8221;</strong> to reveal a distinctly bipolar workforce. Unlike UBA’s &#8220;fat middle,&#8221; Zenith is incredibly top-heavy—<strong>53.1% of the staff</strong> (5,528 people) sit in the highest reported tier (Above ₦9.0M). The second-largest cluster (3,177 people) sits much lower down the ladder in the ₦4.0M–₦6.0M band, leaving a remarkably hollow gap at the bottom and upper-middle levels.
      </p>
    </div>
    
    <div style="margin-top: 24px; padding-top: 16px; border-top: 1px solid #E3E8EF; font-size: 0.75rem; color: #717171; line-height: 1.5;">
      <em>Source: Zenith Bank 2025 Audited Financial Statements.<br>Visualization by TechCabal.</em>
    </div>
  </div>

  <script>
    (function() {
      // The exact 7-tier dataset from Zenith Bank's 2025 financial statement screenshot
      const rawData = [
        { id: 1, label: "₦9,000,001 and above", count: 5528 },
        { id: 2, label: "₦8,000,001 - ₦9,000,000", count: 37 },
        { id: 3, label: "₦6,000,001 - ₦8,000,000", count: 1406 },
        { id: 4, label: "₦4,000,001 - ₦6,000,000", count: 3177 },
        { id: 5, label: "₦2,800,001 - ₦4,000,000", count: 132 },
        { id: 6, label: "₦2,000,001 - ₦2,800,000", count: 28 },
        { id: 7, label: "₦300,001 - ₦2,000,000", count: 89 }
      ];

      const totalStaff = 10397;
      const maxCount = Math.max(...rawData.map(d => d.count));
      const chartContainer = document.getElementById('tc-zenith-chart-render');
      const tooltip = document.getElementById('tc-zenith-tooltip');
      const wrapper = document.getElementById('tc-zenith-app');

      let currentSort = 'hierarchy'; 

      const renderChart = () => {
        chartContainer.innerHTML = '';
        
        // Sort data based on toggle
        let displayData = [...rawData];
        if (currentSort === 'density') {
          displayData.sort((a, b) => b.count - a.count);
        } else {
          displayData.sort((a, b) => a.id - b.id);
        }

        displayData.forEach((band, index) => {
          const pctOfTotal = ((band.count / totalStaff) * 100).toFixed(1);
          const barWidth = ((band.count / maxCount) * 100).toFixed(1);
          
          // Visuals based on density
          const isSpike = band.count > 2500; // Highlights the two massive bipolar pillars
          let barColor = isSpike ? "#EA2D2E" : (band.count < 150 ? "#B0B6BE" : "#FFC52F");
          
          const labelWeight = isSpike ? "700" : "500";
          const textColor = isSpike ? "#151515" : "#4A4A4A";

          const row = document.createElement('div');
          row.className = 'tc-zenith-row';
          row.innerHTML = `
            <div class="tc-zenith-label" style="color: ${textColor}; font-weight: ${labelWeight};">${band.label}</div>
            <div class="tc-zenith-bar-container">
              <div class="tc-zenith-bar-track">
                <div class="tc-zenith-bar-fill" style="width: 0%; background-color: ${barColor};" data-width="${barWidth}%"></div>
              </div>
              <div class="tc-zenith-count" style="color: ${textColor};">${band.count.toLocaleString()}</div>
            </div>
          `;

          // Pointer events handle both desktop mouse and mobile touch accurately
          row.addEventListener('pointerenter', () => {
            tooltip.style.opacity = '1';
            tooltip.innerHTML = `<strong>${pctOfTotal}% of Workforce</strong>${band.count.toLocaleString()} staff members earn<br>${band.label} annually.`;
          });
          
          row.addEventListener('pointermove', (e) => {
            const wrapperRect = wrapper.getBoundingClientRect();
            
            // Initial relative positioning
            let left = e.clientX - wrapperRect.left + 15;
            let top = e.clientY - wrapperRect.top + 15;
            
            // Prevent tooltip from overflowing the right edge on mobile
            const tooltipWidth = tooltip.offsetWidth || 210;
            if (left + tooltipWidth > wrapperRect.width) {
              left = e.clientX - wrapperRect.left - tooltipWidth - 15;
            }
            // Prevent tooltip from overflowing the left edge
            if (left < 10) {
                left = 10;
            }
            
            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
          });

          row.addEventListener('pointerleave', () => {
            tooltip.style.opacity = '0';
          });

          chartContainer.appendChild(row);

          // Animate bars in
          setTimeout(() => {
            const fill = row.querySelector('.tc-zenith-bar-fill');
            fill.style.width = fill.getAttribute('data-width');
          }, 50 + (index * 60)); // Staggered animation
        });
      };

      // Initialization
      renderChart();

      // Button Logic
      const btnHierarchy = document.getElementById('zenith-sort-hierarchy');
      const btnDensity = document.getElementById('zenith-sort-density');

      btnHierarchy.addEventListener('click', () => {
        if (currentSort === 'hierarchy') return;
        currentSort = 'hierarchy';
        btnHierarchy.classList.add('active');
        btnDensity.classList.remove('active');
        renderChart();
      });

      btnDensity.addEventListener('click', () => {
        if (currentSort === 'density') return;
        currentSort = 'density';
        btnDensity.classList.add('active');
        btnHierarchy.classList.remove('active');
        renderChart();
      });

      // Hide tooltip when pointer leaves wrapper
      wrapper.addEventListener('pointerleave', () => {
        tooltip.style.opacity = '0';
      });
      // Global touch dismiss when tapping outside the widget
      document.addEventListener('touchstart', (e) => {
        if (!wrapper.contains(e.target)) {
            tooltip.style.opacity = '0';
        }
      });

    })();
  </script>
</div>



<h2 class="wp-block-heading"><strong>Outsourcing remains entrenched</strong></h2>



<p>Spending on outsourced and contract staff rose by 9.42% to ₦222.82 billion ($163.21 million) in 2025.</p>



<p>These workers, often deployed as tellers and customer service representatives, form a critical part of the Nigerian banking workforce and are usually the first point of contact between the bank and its customers.</p>



<p>According to the <a href="https://www.nigerianstat.gov.ng/elibrary/read/1241238">National Bureau of Statistics</a>, contract staff accounted for 42.75% of the 90,455 banking sector workforce in 2021. Industry estimates suggest banks can cut labour costs by up to 40% through outsourcing, according to the <a href="https://punchng.com/hidden-workforce-how-nigerian-banks-exploit-contract-staff/" target="_blank" rel="noreferrer noopener">Nigeria Employers’ Consultative Association</a>.</p>



<p>The rising wage bill in the financial services sector reveals that talent is becoming one of the most expensive and contested resources in the sector. As banks and fintechs compete for the same workers, the cost of keeping staff is likely to remain high, with implications for profitability and service delivery.</p>



<p><strong>Note: exchange rate used: ₦1,365.25/$</strong></p>



<p></p>



<p></p>
