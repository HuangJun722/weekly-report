            <img decoding="async" style="width: 100%; height: auto;" 
     	loading="lazy" src="https://c76c7bbc41.mjedge.net/wp-content/uploads/tc/2022/06/next-wave-header.png" alt="Next Wave Logo">
        </div>
        <!-- <div id="main_content_wrapper" style="position: relative; z-index: 2; padding:15px 10px">
