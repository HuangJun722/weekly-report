      { c: "São Tomé and Príncipe", v: 1, r: 16.67 }, { c: "Senegal", v: 425, r: 4.30 }, { c: "Seychelles", v: 2, r: 0.81 },
      { c: "Tanzania", v: 515, r: 8.30 }, { c: "Togo", v: 417, r: 16.11 }, { c: "Tunisia", v: 204, r: 2.18 },
      { c: "Uganda", v: 621, r: 6.78 }, { c: "Zambia", v: 453, r: 10.73 }, { c: "Zimbabwe", v: 722, r: 7.89 }
    ];

    function tcSortOverstays(metric) {
      const btnRate = document.getElementById('tc-btn-rate');
      const btnVol = document.getElementById('tc-btn-vol');
      
      if(metric === 'rate') {
        btnRate.style.background = '#EA2D2E'; btnRate.style.color = '#FFF';
        btnVol.style.background = '#F6F6F6'; btnVol.style.color = '#EA2D2E';
      } else {
        btnVol.style.background = '#EA2D2E'; btnVol.style.color = '#FFF';
        btnRate.style.background = '#F6F6F6'; btnRate.style.color = '#EA2D2E';
      }

      const sorted = [...tcOverstayData].sort((a, b) => b[metric === 'rate' ? 'r' : 'v'] - a[metric === 'rate' ? 'r' : 'v']);
      const maxVal = Math.max(...sorted.map(d => d[metric === 'rate' ? 'r' : 'v']));
      const container = document.getElementById('tc-overstay-list');
      container.innerHTML = '';

      sorted.forEach(d => {
        let width = (d[metric === 'rate' ? 'r' : 'v'] / maxVal) * 100;
        let displayVal = metric === 'rate' ? d.r + '%' : d.v.toLocaleString();
        container.innerHTML += `
          <div class="tc-v1-row">
            <div class="tc-v1-label">${d.c}</div>
            <div class="tc-v1-track">
              <div style="background: #EA2D2E; height: 100%; width: ${width}%; transition: width 0.4s ease;"></div>
            </div>
            <div class="tc-v1-val">${displayVal}</div>
          </div>
        `;
      });
    }
    tcSortOverstays('rate');
  </script>
