    <button class="tc-tab-btn" onclick="tcRenderDashboard('deposits')">Customer Deposits</button>
  </div>

  <div class="tc-editorial-insight" id="tc-main-insight">
    </div>

  <div class="tc-chart-area" id="tc-chart-area">
