		<title>NGX nearly doubles profit as transaction fee income climbs 189%</title>
		<link>https://techcabal.com/2026/05/01/ngx-nearly-doubles-profit-as-transaction-fee-income-climbs-189/</link>
		
		<dc:creator><![CDATA[Temitayo Jaiyeola]]></dc:creator>
		<pubDate>Fri, 01 May 2026 12:55:21 +0000</pubDate>
				<category><![CDATA[Companies]]></category>
		<category><![CDATA[NGX]]></category>
		<category><![CDATA[Nigeria]]></category>
		<category><![CDATA[Retail investors]]></category>
