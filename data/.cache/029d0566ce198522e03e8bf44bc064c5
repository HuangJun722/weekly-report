    <!-- RESERVE BREAKDOWN -->
    <div style="display: grid; grid-template-columns: 1fr; gap: 16px; margin-bottom: 24px;">
        <!-- 30% Bank Portion -->
        <div style="background: #E8341A; color: #FFFFFF; border-radius: 12px; padding: 20px; position: relative; overflow: hidden;">
            <div style="position: absolute; right: -10px; bottom: -10px; font-size: 4rem; opacity: 0.1; font-weight: 900;">30%</div>
