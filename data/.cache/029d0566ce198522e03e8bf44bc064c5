		<title>Eric Asuma on childhood, ambition, and refusing to sell Kenyan Wall Street</title>
		<link>https://techcabal.com/2026/06/05/eric-asuma-childhood-ambition-kenyan-wall-street/</link>
		
		<dc:creator><![CDATA[Adonijah Ndege]]></dc:creator>
		<pubDate>Fri, 05 Jun 2026 14:10:13 +0000</pubDate>
				<category><![CDATA[People]]></category>
