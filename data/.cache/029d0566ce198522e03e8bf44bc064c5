		<title>This startup is building an ‘intelligence layer’ for Nigeria’s power grid</title>
		<link>https://techcabal.com/2026/04/09/powerlabs-wants-to-make-nigerias-grid-think/</link>
		
		<dc:creator><![CDATA[Frank Eleanya]]></dc:creator>
		<pubDate>Thu, 09 Apr 2026 11:56:07 +0000</pubDate>
				<category><![CDATA[Features]]></category>
		<category><![CDATA[Africa]]></category>
