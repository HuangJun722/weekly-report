      {c:"Mozambique", y22:935, y23:1451, y24:1385}, {c:"Namibia", y22:928, y23:1301, y24:1084},
      {c:"Nigeria", y22:69047, y23:97151, y24:72534}, {c:"São Tomé and Príncipe", y22:11, y23:8, y24:12},
