		<title>Nigeria’s central bank expands PoS operating radius to 70 metres</title>
		<link>https://techcabal.com/2026/05/30/nigerias-central-bank-expands-pos-operating-radius-to-70-metres/</link>
		
		<dc:creator><![CDATA[Temitayo Jaiyeola]]></dc:creator>
		<pubDate>Sat, 30 May 2026 08:14:21 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[CBN]]></category>
		<category><![CDATA[Nigeria]]></category>
