		<title>Safaricom is pushing M-PESA deeper into Kenya’s retail investing market</title>
		<link>https://techcabal.com/2026/05/08/safaricom-expands-m-pesa-wealth-push-as-ziidi-assets-double/</link>
		
		<dc:creator><![CDATA[Kenn Abuya]]></dc:creator>
		<pubDate>Fri, 08 May 2026 06:13:04 +0000</pubDate>
				<category><![CDATA[Telecoms]]></category>
		<category><![CDATA[Safaricom]]></category>
