		<title>Quick Fire 🔥 with Kolawole Bekes</title>
		<link>https://techcabal.com/2026/04/24/quick-fire-%f0%9f%94%a5-with-kolawole-bekes/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Fri, 24 Apr 2026 06:12:01 +0000</pubDate>
				<category><![CDATA[Quick Fire]]></category>
