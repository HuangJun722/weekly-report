        btnVol.style.background = '#EA2D2E'; btnVol.style.color = '#FFF';
        btnRate.style.background = '#F6F6F6'; btnRate.style.color = '#EA2D2E';
      }

      const sorted = [...tcOverstayData].sort((a, b) => b[metric === 'rate' ? 'r' : 'v'] - a[metric === 'rate' ? 'r' : 'v']);
      const maxVal = Math.max(...sorted.map(d => d[metric === 'rate' ? 'r' : 'v']));
      const container = document.getElementById('tc-overstay-list');
      container.innerHTML = '';

      sorted.forEach(d => {
        let width = (d[metric === 'rate' ? 'r' : 'v'] / maxVal) * 100;
        let displayVal = metric === 'rate' ? d.r + '%' : d.v.toLocaleString();
        container.innerHTML += `
          <div class="tc-v1-row">
            <div class="tc-v1-label">${d.c}</div>
            <div class="tc-v1-track">
              <div style="background: #EA2D2E; height: 100%; width: ${width}%; transition: width 0.4s ease;"></div>
