		<category><![CDATA[Chpter]]></category>
		<category><![CDATA[cloud9]]></category>
		<category><![CDATA[Fintech]]></category>
		<category><![CDATA[Kenya]]></category>
		<category><![CDATA[marketforce]]></category>
