  <script>
    // Mathematical Breakdown for 2025 (Normalized to 100 Deposits)
    const tcUnitData = {
      GTCO: {
        loans: 13.6, // (30.9 / 226.4) * 100
        cash: 22.2,  // (50.3 / 226.4) * 100
        income: 12.2, // (27.6 / 226.4) * 100
