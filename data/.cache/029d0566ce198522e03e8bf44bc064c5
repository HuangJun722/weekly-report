		<title>Amaya wants to become the operating system for African agriculture</title>
		<link>https://techcabal.com/2026/05/12/francophone-weekly-by-techcabal-022/</link>
		
		<dc:creator><![CDATA[Lina Kacyem]]></dc:creator>
		<pubDate>Tue, 12 May 2026 12:35:57 +0000</pubDate>
				<category><![CDATA[Francophone Weekly]]></category>
