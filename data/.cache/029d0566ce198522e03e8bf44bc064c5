      return;
    }
    input.value = parseInt(value, 10).toLocaleString('en-US');
  }

  function tcCalculateFootprint() {
    // Parse values, removing commas
    const rawData = document.getElementById('tc-data-spend').value.replace(/,/g, '');
    const rawVoice = document.getElementById('tc-voice-spend').value.replace(/,/g, '');
    
    const dataSpend = parseFloat(rawData) || 0;
    const voiceSpend = parseFloat(rawVoice) || 0;
    
    if(dataSpend === 0 && voiceSpend === 0) return;

    // Button loading animation
    const btn = document.getElementById('tc-calc-btn');
    const originalText = btn.innerHTML;
    btn.innerHTML = `<span style="opacity: 0.8;">Calculating...</span>`;
    btn.style.transform = 'scale(0.98)';
    
    setTimeout(() => {
      // Core Logic
      const totalMonthly = dataSpend + voiceSpend;
      const totalYearly = totalMonthly * 12;
      const gbYearly = (dataSpend * 12) / 575; // Using N575 per GB from article
      const tiktokHours = gbYearly * 1.5; // Rough estimate: 1GB = 1.5 hours of social video
      
      const dataPct = Math.round((dataSpend / totalMonthly) * 100);
      const voicePct = Math.round((voiceSpend / totalMonthly) * 100);
      
      // Reveal Results container
      const resultsDiv = document.getElementById('tc-results');
      resultsDiv.style.display = 'block';
      
      // Update DOM with animated counter feel
      document.getElementById('tc-yearly-spend').innerText = totalYearly.toLocaleString('en-NG');
