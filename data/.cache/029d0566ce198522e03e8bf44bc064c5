		<title>Glovo says Nigeria is its fastest-growing market after expansion push</title>
		<link>https://techcabal.com/2026/04/24/glovo-names-nigeria-fastest-growing-market/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Fri, 24 Apr 2026 09:37:10 +0000</pubDate>
				<category><![CDATA[News]]></category>
