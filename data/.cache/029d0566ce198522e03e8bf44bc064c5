                var platform = document.getElementById('tc-platform');
                if(platform) platform.classList.remove('collapsed');
                var btnDrop = document.getElementById('tc-drop-btn');
                if(btnDrop){ btnDrop.style.background = '#EA2D2E'; btnDrop.style.boxShadow = '0 4px 0 #B22222'; btnDrop.innerText = "&#x2b07; Drop Market Shock"; btnDrop.style.cursor = 'pointer'; }
                var statusMsg = document.getElementById('tc-status-msg');
                if(statusMsg){ statusMsg.style.color = '#20C997'; statusMsg.innerText = "System stable. Ready for load testing."; }
                this.render();
            }
        };
