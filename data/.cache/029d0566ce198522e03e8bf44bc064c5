		<title>Why Kenyan digital bank Cloud9 acquired Mtickets in $773,000 deal</title>
		<link>https://techcabal.com/2026/05/19/cloud9-acquired-mtickets/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Tue, 19 May 2026 16:33:06 +0000</pubDate>
				<category><![CDATA[Startups]]></category>
