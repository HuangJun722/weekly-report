  <script>
    (function() {
      // The 17-tier dataset
      const rawData = [
        { id: 1, label: "Above ₦45.3M", count: 764 },
        { id: 2, label: "₦30.2M - ₦45.3M", count: 181 },
        { id: 3, label: "₦26.2M - ₦30.2M", count: 631 },
