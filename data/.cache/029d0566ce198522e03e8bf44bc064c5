    <div class="tc-arrow-down">↓</div>

    <!-- Stage 4: Output -->
    <div class="tc-pipeline-stage" style="justify-content: center;">
      <div class="tc-unit-card" id="tc-card-profit">
        <div class="tc-card-label">The Bottom Line</div>
        <div class="tc-card-value" id="tc-val-profit">₦0.0</div>
        <div class="tc-card-subtext" id="tc-sub-profit">Net Profit per ₦100</div>
      </div>
