  <!-- Editorial Summary -->
  <div id="tc-unit-summary-text" style="margin-top: 24px; padding: 14px 16px; background: #F6F6F6; border-left: 3px solid #EA2D2E; border-radius: 0 4px 4px 0; font-size: 0.9rem; color: #151515; line-height: 1.6;">
