    <script>
        const rates = { mar: -0.02, apr: 0.159, may: 0.01734 };
        const maxAbsRate = 0.16; // Used to scale bar heights relative to container

        function formatMoney(amount, isDifference = false) {
            const prefix = isDifference ? (amount < 0 ? '-₦' : '+₦') : '₦';
            return prefix + Math.abs(amount).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }

        function formatFullMoney(amount) {
            return '₦' + amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        // Syncs Slider to Text Input
        function handleSliderInput(event) {
            const val = event.target.value;
            const textInput = document.getElementById('tc-vol-text');
            textInput.value = Number(val).toLocaleString('en-US');
            calculateVolatility(Number(val));
        }

        // Syncs Text Input to Slider
        function handleTextInput(event) {
            let inputField = event.target;
            let unformatted = inputField.value.replace(/[^0-9.]/g, '');
            if(unformatted === '') unformatted = '0';
            
            let parts = unformatted.split('.');
            parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            inputField.value = parts.join('.');
            
            const numVal = parseFloat(unformatted);
            const slider = document.getElementById('tc-vol-slider');
            
            // Allow slider to scale up if user types a huge number
            if(numVal > slider.max) {
                slider.max = numVal;
            }
            slider.value = numVal;

            calculateVolatility(numVal);
        }

        function calculateVolatility(principal) {
            if(isNaN(principal) || principal <= 0) {
                document.getElementById('tc-val-mar').style.opacity = '0';
                document.getElementById('tc-val-apr').style.opacity = '0';
                document.getElementById('tc-val-may').style.opacity = '0';
                document.getElementById('tc-bar-mar').style.height = '0%';
                document.getElementById('tc-bar-apr').style.height = '0%';
                document.getElementById('tc-bar-may').style.height = '0%';
                document.getElementById('tc-vol-total').innerText = '₦0.00';
                return;
            }

            const marVal = principal * rates.mar;
            const aprVal = principal * rates.apr;
            const mayVal = principal * rates.may;
            const finalBalance = principal + marVal + aprVal + mayVal;

            // Update Heights (Scaled to 100% of their half-containers)
            document.getElementById('tc-bar-mar').style.height = ((Math.abs(rates.mar) / maxAbsRate) * 100) + '%';
            document.getElementById('tc-bar-apr').style.height = ((Math.abs(rates.apr) / maxAbsRate) * 100) + '%';
            document.getElementById('tc-bar-may').style.height = ((Math.abs(rates.may) / maxAbsRate) * 100) + '%';

            // Update Labels
            const valMar = document.getElementById('tc-val-mar');
            const valApr = document.getElementById('tc-val-apr');
            const valMay = document.getElementById('tc-val-may');

            valMar.innerText = formatMoney(marVal, true);
            valApr.innerText = formatMoney(aprVal, true);
            valMay.innerText = formatMoney(mayVal, true);

            valMar.style.opacity = '1';
            valApr.style.opacity = '1';
            valMay.style.opacity = '1';

            // Update Total
            document.getElementById('tc-vol-total').innerText = formatFullMoney(finalBalance);
        }
    </script>
