                var dropZone = document.getElementById('tc-drop-zone');
                var block = document.createElement('div');
                block.className = 'tc-falling-block tc-block-item';
                var randomLeft = 20 + Math.random() * 60;
                block.style.left = randomLeft + '%';
                block.style.top = '-80px';
                block.innerText = "&#x1f4a5;";
                if(dropZone) dropZone.appendChild(block);
