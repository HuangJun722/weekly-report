          container.innerHTML += regionHtml;
        });

        // Trigger animation shortly after render
        setTimeout(() => {
          const bars = container.querySelectorAll('div[data-width]');
          bars.forEach(bar => {
            bar.style.width = bar.getAttribute('data-width');
