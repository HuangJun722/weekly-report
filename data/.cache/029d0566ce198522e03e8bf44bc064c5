<div id="Story4" style="padding:0 12px;box-sizing:border-box;">
                <div class="section_heading" style="width:100%; background-color: transparent;box-sizing:border-box;padding-bottom:12px;">
                    <div id="web3" style="width:100%;max-width:115px;height:1px;background-color:#D3D3D3;margin:24px auto; ">
