		<title>At AVCA summit, investors push pragmatic approach as Africa&#8217;s exits surge</title>
		<link>https://techcabal.com/2026/04/29/avca-imported-venture-models-african-exits/</link>
		
		<dc:creator><![CDATA[Adonijah Ndege]]></dc:creator>
		<pubDate>Wed, 29 Apr 2026 17:03:06 +0000</pubDate>
				<category><![CDATA[Events]]></category>
