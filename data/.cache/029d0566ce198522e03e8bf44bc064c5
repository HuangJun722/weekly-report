		<title>👨🏿‍🚀TechCabal Daily – New tax chief, old problem</title>
		<link>https://techcabal.com/2026/05/21/techcabal-daily-new-tax-chief-old-problem/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Thu, 21 May 2026 06:26:43 +0000</pubDate>
				<category><![CDATA[Newsletters]]></category>
		<category><![CDATA[TC Daily]]></category>
		<category><![CDATA[Africa]]></category>
		<category><![CDATA[Artifical Intelligence]]></category>
		<category><![CDATA[Kenya]]></category>
		<category><![CDATA[Nigeria]]></category>
