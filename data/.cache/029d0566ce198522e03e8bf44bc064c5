		<title>Quick Fire 🔥 with Sarah Wahinya</title>
		<link>https://techcabal.com/2026/05/08/quick-fire-%f0%9f%94%a5-with-sarah-wahinya/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Fri, 08 May 2026 06:03:17 +0000</pubDate>
				<category><![CDATA[Quick Fire]]></category>
		<category><![CDATA[Africa]]></category>
		<category><![CDATA[Kenya]]></category>
