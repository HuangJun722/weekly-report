<div id="Story2" style="padding:0 12px">
                <div class="section_heading" style="width:100%;background-color: transparent;padding-bottom:12px">
                    <div id="web3" style="width:100%;max-width:115px;height:1px;background-color:#D3D3D3;margin:24px auto">
                    </div>
                    <h3 style="padding:0;width:100%;font-family:Georgia, 'Times New Roman', Times, serif;font-weight:700;font-size:16px;color:#93888F;line-height:23.1px;text-align: left;margin:0;text-transform:uppercase">Companies</h3>
