		<title>Stablecoin payments infrastructure startup Checker raises $8 million for Africa, Asia expansion</title>
		<link>https://techcabal.com/2026/05/20/checker-raises-8-million/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Wed, 20 May 2026 07:33:03 +0000</pubDate>
