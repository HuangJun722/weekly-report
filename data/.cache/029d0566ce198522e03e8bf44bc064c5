      document.getElementById('tc-tiktok-hours').innerText = Math.round(tiktokHours).toLocaleString('en-US');
      
      // Update Progress Bar
      document.getElementById('tc-data-pct').innerText = dataPct + '%';
      document.getElementById('tc-voice-pct').innerText = voicePct + '%';
      
      // Small delay for CSS transition to kick in on width
