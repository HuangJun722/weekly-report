    <div id="tc-status-msg" style="text-align: center; margin-top: 16px; font-size: 0.875rem; font-weight: 700; color: #20C997; min-height: 20px; transition: color 0.3s;">System stable. Ready for load testing.</div>

    <script>
        /* <![CDATA[ */
        window.tcSim = {
            mode: 'ceo',
            shocks: 0,
            collapsed: false,
            maxLoad: 2,
            setMode: function(mode) {
                this.mode = mode;
                var btnCeo = document.getElementById('tc-btn-ceo');
                var btnCathedral = document.getElementById('tc-btn-cathedral');
                if (mode === 'ceo') {
                    if(btnCeo) { btnCeo.style.background = '#FFFFFF'; btnCeo.style.color = '#151515'; }
                    if(btnCathedral) { btnCathedral.style.background = 'transparent'; btnCathedral.style.color = '#E3E8EF'; }
                } else {
                    if(btnCathedral) { btnCathedral.style.background = '#FFFFFF'; btnCathedral.style.color = '#151515'; }
                    if(btnCeo) { btnCeo.style.background = 'transparent'; btnCeo.style.color = '#E3E8EF'; }
                }
                this.reset();
            },
            render: function() {
                var container = document.getElementById('tc-supports');
                if (!container) return;
                if (this.mode === 'ceo') {
                    container.innerHTML = '<div id="tc-pillar-main" class="tc-pillar" style="width: 40px; height: 100%; background: #FFC52F; border-radius: 4px 4px 0 0; box-shadow: inset -4px 0 rgba(0,0,0,0.2);"></div>';
                } else {
                    var html = '';
                    for (var i = 0; i < 11; i++) {
                        html += '<div class="tc-pillar tc-avp-pillar" style="flex: 1; max-width: 12px; height: 100%; background: #20C997; border-radius: 2px 2px 0 0; box-shadow: inset -2px 0 rgba(0,0,0,0.2);"></div>';
                    }
                    container.innerHTML = html;
                }
            },
            drop: function() {
                if (this.collapsed) return;
                this.shocks++;
                var dropZone = document.getElementById('tc-drop-zone');
                var block = document.createElement('div');
                block.className = 'tc-falling-block tc-block-item';
                var randomLeft = 20 + Math.random() * 60;
                block.style.left = randomLeft + '%';
                block.style.top = '-80px';
                block.innerText = "&#x1f4a5;";
                if(dropZone) dropZone.appendChild(block);
                var self = this;
                setTimeout(function() {
                    block.style.top = '144px';
                    setTimeout(function() {
                        var sandbox = document.getElementById('tc-sandbox');
                        if(sandbox) {
                            sandbox.classList.remove('tc-shake');
                            void sandbox.offsetWidth;
                            sandbox.classList.add('tc-shake');
                        }
                        self.check();
                    }, 400);
                }, 50);
            },
            check: function() {
                var statusMsg = document.getElementById('tc-status-msg');
                if (this.mode === 'ceo') {
                    var pillar = document.getElementById('tc-pillar-main');
                    if (this.shocks === 1) {
                        if(pillar) pillar.style.background = '#FF9800';
                        if(statusMsg){ statusMsg.style.color = '#FF9800'; statusMsg.innerText = "CEO under strain. Bottlenecks forming."; }
                    } else if (this.shocks === 2) {
                        if(pillar) pillar.style.background = '#EA2D2E';
                        if(statusMsg){ statusMsg.style.color = '#EA2D2E'; statusMsg.innerText = "CRITICAL LOAD. A single point of failure is buckling."; }
                    } else if (this.shocks > this.maxLoad) {
                        this.collapse(pillar);
                    }
                } else {
                    var pillars = document.querySelectorAll('.tc-avp-pillar');
                    for (var i = 0; i < pillars.length; i++) {
                        (function(p) {
                            p.style.background = '#FFFFFF';
                            setTimeout(function(){ p.style.background = '#20C997'; }, 200);
                        })(pillars[i]);
                    }
                    if(statusMsg){ statusMsg.style.color = '#20C997'; statusMsg.innerText = "Shock absorbed. 11 AVPs distributed the load. (Load: " + this.shocks + ")"; }
                }
            },
            collapse: function(pillar) {
                this.collapsed = true;
                if(pillar) pillar.classList.add('broken');
                var platform = document.getElementById('tc-platform');
                if(platform) platform.classList.add('collapsed');
                var blocks = document.querySelectorAll('.tc-block-item');
                for (var i = 0; i < blocks.length; i++) {
                    (function(b, index) {
                        setTimeout(function(){ b.classList.add('tc-block-slide'); }, index * 100);
                    })(blocks[i], i);
                }
                var statusMsg = document.getElementById('tc-status-msg');
                if(statusMsg){ statusMsg.style.color = '#EA2D2E'; statusMsg.innerText = "&#x1f6a8; SYSTEM FAILURE. The founder broke under scale."; }
                var btnDrop = document.getElementById('tc-drop-btn');
                if(btnDrop){ btnDrop.style.background = '#3A3F45'; btnDrop.style.boxShadow = 'none'; btnDrop.innerText = "System Offline"; btnDrop.style.cursor = 'not-allowed'; }
            },
            reset: function() {
                this.collapsed = false;
                this.shocks = 0;
                var dropZone = document.getElementById('tc-drop-zone');
