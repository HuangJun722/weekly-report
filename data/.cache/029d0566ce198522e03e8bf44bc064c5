		<category><![CDATA[chowdeck]]></category>
		<category><![CDATA[food delivery]]></category>
		<category><![CDATA[Glovo]]></category>
		<category><![CDATA[GoLemon]]></category>
		<category><![CDATA[Nigeria]]></category>
