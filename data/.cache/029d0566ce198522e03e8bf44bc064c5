            <span style="font-size: 0.75rem; font-weight: 700; color: #4A5568; position: absolute; bottom: -24px; pointer-events: none;">${year}</span>
          </div>
        `;
        hostContainer.innerHTML += markupBlock;
      });

      tableContainer.innerHTML = tableHTML;
    }

