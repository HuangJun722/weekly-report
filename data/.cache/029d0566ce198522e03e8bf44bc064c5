  <script>
    (function() {
      const revenueData = {
        max: 2.5, // Slightly higher than East Africa's 2.19B to give visual breathing room
        prefix: '$',
        suffix: 'B',
        regions: [
          { 
            name: 'East Africa', 
            val2025: 1.84, 
