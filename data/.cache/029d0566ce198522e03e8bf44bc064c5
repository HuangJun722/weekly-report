        { id: 5, label: "₦17.9M - ₦21.9M", count: 2850 },
        { id: 6, label: "₦14.9M - ₦17.9M", count: 51 },
        { id: 7, label: "₦11.3M - ₦14.9M", count: 2036 },
        { id: 8, label: "₦9.1M - ₦11.3M", count: 106 },
        { id: 9, label: "₦8.7M - ₦9.1M", count: 2 },
        { id: 10, label: "₦7.4M - ₦8.7M", count: 2531 },
        { id: 11, label: "₦6.7M - ₦7.4M", count: 59 },
        { id: 12, label: "₦5.7M - ₦6.7M", count: 386 },
        { id: 13, label: "₦4.7M - ₦5.7M", count: 60 },
        { id: 14, label: "₦3.9M - ₦4.7M", count: 122 },
        { id: 15, label: "₦2.9M - ₦3.9M", count: 72 },
        { id: 16, label: "₦1.9M - ₦2.9M", count: 22 },
        { id: 17, label: "₦900k - ₦1.9M", count: 48 }
      ];

      const totalStaff = 9960;
      const maxCount = Math.max(...rawData.map(d => d.count));
      const chartContainer = document.getElementById('tc-chart-render');
      const tooltip = document.getElementById('tc-tooltip');
      const wrapper = document.getElementById('tc-salary-app');

      let currentSort = 'hierarchy';

      const renderChart = () => {
        chartContainer.innerHTML = '';
        
        let displayData = [...rawData];
        if (currentSort === 'density') {
          displayData.sort((a, b) => b.count - a.count);
        } else {
          displayData.sort((a, b) => a.id - b.id);
        }

        displayData.forEach((band, index) => {
          const pctOfTotal = ((band.count / totalStaff) * 100).toFixed(1);
          const barWidth = ((band.count / maxCount) * 100).toFixed(1);
          
          const isSpike = band.count > 1000;
          const barColor = isSpike ? "#EA2D2E" : (band.count > 100 ? "#FFC52F" : "#B0B6BE");
          
          const row = document.createElement('div');
          row.className = 'tc-row';
          row.innerHTML = `
            <div class="tc-label" style="color: ${isSpike ? '#151515' : '#4A4A4A'};">${band.label}</div>
            <div class="tc-bar-container">
              <div class="tc-bar-track">
