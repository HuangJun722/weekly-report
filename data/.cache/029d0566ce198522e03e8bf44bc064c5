		<title>Quick Fire 🔥 with Segun Akinnibosun</title>
		<link>https://techcabal.com/2026/04/17/quick-fire-%f0%9f%94%a5-with-segun-akinnibosun/</link>
		
		<dc:creator><![CDATA[Opeyemi Kareem]]></dc:creator>
		<pubDate>Fri, 17 Apr 2026 06:11:39 +0000</pubDate>
				<category><![CDATA[Quick Fire]]></category>
		<category><![CDATA[Africa]]></category>
		<category><![CDATA[Kenya]]></category>
		<category><![CDATA[Nigeria]]></category>
		<category><![CDATA[TC Daily]]></category>
