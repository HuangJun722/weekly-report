      </p>
    </div>

    <!-- INPUT SECTION -->
    <div style="background: #FFFFFF; border-radius: 12px; padding: 20px; border: 1px solid #E2DDD6; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
