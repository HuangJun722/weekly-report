		<title>Coral Raises $12.5 Million To Automate Healthcare Administration</title>
		<link>https://ventureburn.com/coral-raises-12-5-million-to-automate-healthcare-administration/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
