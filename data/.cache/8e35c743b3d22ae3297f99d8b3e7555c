		<title>Focused Energy Raises $240M to Advance Fusion Power</title>
		<link>https://ventureburn.com/focused-energy-raises-240m-to-advance-fusion-power/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
