		<title>Blnk Raises $12.5M Series A to Expand Consumer Finance Across MENA</title>
		<link>https://ventureburn.com/blnk-raises-12-5m-series-a-consumer-finance-expansion/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
