		<title>Geordie Raises $30M to Secure Enterprise AI Agents</title>
		<link>https://ventureburn.com/geordie-raises-30m-to-secure-enterprise-ai-agents/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Thu, 28 May 2026 15:30:40 +0000</pubDate>
