		<title>Merantix Capital Launches €103M Fund for European AI</title>
		<link>https://ventureburn.com/merantix-capital-launches-e103m-fund-for-european-ai/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Thu, 04 Jun 2026 09:30:16 +0000</pubDate>
				<category><![CDATA[News]]></category>
