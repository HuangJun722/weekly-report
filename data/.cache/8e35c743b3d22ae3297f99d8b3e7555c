		<title>Ent Raises $100M Seed Funding to Reinvent Cybersecurity for the AI Era</title>
		<link>https://ventureburn.com/ent-raises-100m-seed-workspace-security/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 17 Jun 2026 20:20:47 +0000</pubDate>
				<category><![CDATA[News]]></category>
