		<title>Gigaton Raises $26M to Transform Industrial Control</title>
		<link>https://ventureburn.com/gigaton-raises-26m-to-transform-industrial-control/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Wed, 03 Jun 2026 16:08:14 +0000</pubDate>
				<category><![CDATA[News]]></category>
