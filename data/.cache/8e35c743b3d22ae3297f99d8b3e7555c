		<title>Salmon Bags $100M to Scale Digital Banking Solutions</title>
		<link>https://ventureburn.com/salmon-bags-100m-to-scale-digital-banking-solutions/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Wed, 22 Apr 2026 13:44:08 +0000</pubDate>
				<category><![CDATA[News]]></category>
