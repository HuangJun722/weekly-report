		<title>PointFive Raises $60 Million to Expand AI Efficiency Platform</title>
		<link>https://ventureburn.com/pointfive-raises-60-million-expand-ai-efficiency-platform/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Mon, 08 Jun 2026 14:40:53 +0000</pubDate>
