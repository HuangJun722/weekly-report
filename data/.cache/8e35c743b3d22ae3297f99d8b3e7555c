		<title>Relay Secures $50 Million to Scale Small Business Banking Platform</title>
		<link>https://ventureburn.com/relay-secures-50-million-growth-investment/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Tue, 19 May 2026 13:05:51 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[Startup]]></category>
