		<title>Astranis Raises $450 Million to Expand GEO Satellite Production</title>
		<link>https://ventureburn.com/astranis-raises-450-million-to-expand-geo-satellite-production/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 06 May 2026 15:05:48 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[Venture Capital]]></category>
