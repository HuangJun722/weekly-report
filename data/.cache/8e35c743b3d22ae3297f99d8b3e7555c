		<link>https://ventureburn.com/eyeo-raises-40m-series-a-to-advance-nanophotonic-sensor-technology/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Mon, 11 May 2026 14:51:23 +0000</pubDate>
