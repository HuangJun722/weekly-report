		<title>Quartermaster Raises $43M to Transform Ocean Tracking</title>
		<link>https://ventureburn.com/quartermaster-raises-43m-to-transform-ocean-tracking/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Fri, 22 May 2026 15:38:41 +0000</pubDate>
				<category><![CDATA[News]]></category>
