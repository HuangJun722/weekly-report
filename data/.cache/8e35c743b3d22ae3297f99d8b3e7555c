		<link>https://ventureburn.com/reps-raises-23-6m-to-turn-roads-into-power-plants/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Mon, 25 May 2026 15:59:22 +0000</pubDate>
