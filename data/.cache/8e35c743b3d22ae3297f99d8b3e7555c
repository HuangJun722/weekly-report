		<title>Viktor Raises $75M for Slack and Teams AI Growth</title>
		<link>https://ventureburn.com/viktor-raises-75m-for-slack-and-teams-ai-growth/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Wed, 20 May 2026 15:04:26 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[Venture Capital]]></category>
