		<title>Flutterwave Raises $250M Series E at $3.2B Valuation with Ripple Strategic Backing</title>
		<link>https://ventureburn.com/flutterwave-raises-250m-series-e/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 17 Jun 2026 20:37:19 +0000</pubDate>
