		<link>https://ventureburn.com/syntheticfi-raises-13m-surpasses-2b-in-assets/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Tue, 09 Jun 2026 14:52:31 +0000</pubDate>
