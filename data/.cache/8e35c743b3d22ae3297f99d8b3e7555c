		<title>CertifID Raises $47.5M To Strengthen Real Estate Fraud Protection</title>
		<link>https://ventureburn.com/certifid-raises-47-5m/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 09 Apr 2026 11:45:10 +0000</pubDate>
