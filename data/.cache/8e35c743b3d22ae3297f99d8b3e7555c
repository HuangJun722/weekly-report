		<title>Quantifind Raises $200M to Expand AI Risk Intelligence</title>
		<link>https://ventureburn.com/quantifind-raises-200m-to-expand-ai-risk-intelligence/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
