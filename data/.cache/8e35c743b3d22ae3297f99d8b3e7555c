		<title>Highland Europe Backs Unframe’s $50M AI Expansion</title>
		<link>https://ventureburn.com/highland-europe-backs-unframes-50m-ai-expansion/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Tue, 19 May 2026 12:42:41 +0000</pubDate>
				<category><![CDATA[News]]></category>
