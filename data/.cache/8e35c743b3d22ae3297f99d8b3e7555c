		<title>Jeito Capital Raises $1.2B to Drive European Biopharma Growth</title>
		<link>https://ventureburn.com/jeito-capital-1-2b/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 08 Apr 2026 14:05:46 +0000</pubDate>
