		<title>GridCARE Raises $64M to Launch AI Energy Category</title>
		<link>https://ventureburn.com/gridcare-raises-64m-to-launch-ai-energy-category/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Thu, 14 May 2026 19:27:53 +0000</pubDate>
				<category><![CDATA[News]]></category>
