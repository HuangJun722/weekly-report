		<title>Two Desperados Secures $20M UA Financing to Scale Mobile Gaming Portfolio</title>
		<link>https://ventureburn.com/two-desperados-secures-20m-ua-financing/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 10 Jun 2026 14:05:39 +0000</pubDate>
				<category><![CDATA[News]]></category>
