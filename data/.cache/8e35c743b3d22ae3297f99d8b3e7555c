</tr>
<tr>
<td><span style="font-weight: 400;">Bitcoin Hyper (HYPER)</span></td>
<td><span style="font-weight: 400;">Bitcoin L2</span></td>
<td><span style="font-weight: 400;">Bitcoin</span></td>
<td><span style="font-weight: 400;">CertiK, SpyWolf</span></td>
<td><span style="font-weight: 400;">Active</span></td>
