		<title>Proxima Fusion Secures €411M From Google, RWE To Build Europe’s Commercial Fusion Champion</title>
		<link>https://ventureburn.com/proxima-fusion-secures-411m-funding-google-backing/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Tue, 07 Jul 2026 07:48:28 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[Startup]]></category>
		<category><![CDATA[AI]]></category>
