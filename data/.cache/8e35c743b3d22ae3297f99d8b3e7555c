		<title>Evotrex Raises $30M Series A to Advance Power-Generating RV Development</title>
		<link>https://ventureburn.com/evotrex-raises-30m-series-a-rv-development/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 10 Jun 2026 13:34:10 +0000</pubDate>
				<category><![CDATA[News]]></category>
