		<title>Fresha Raises $80M, Hits $1 Billion Valuation</title>
		<link>https://ventureburn.com/fresha-raises-80m-hits-1-billion-valuation/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Fri, 22 May 2026 18:28:21 +0000</pubDate>
