		<title>Exaforce Raises $125M Series B To Scale AI Native Security Operations Platform</title>
		<link>https://ventureburn.com/exaforce-raises-125m-series-b-to-scale-ai-native-security-operations-platform/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Tue, 12 May 2026 17:25:31 +0000</pubDate>
				<category><![CDATA[AI]]></category>
		<category><![CDATA[News]]></category>
