		<title>Voice AI Startup Gradium Raises $100M Seed for Global Expansion</title>
		<link>https://ventureburn.com/voice-ai-startup-gradium-raises-100m-seed/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Fri, 10 Jul 2026 13:18:38 +0000</pubDate>
