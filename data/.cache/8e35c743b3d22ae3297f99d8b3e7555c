		<link>https://ventureburn.com/minerva-raises-20m-to-transform-marketing-technology/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Wed, 10 Jun 2026 10:21:21 +0000</pubDate>
				<category><![CDATA[News]]></category>
