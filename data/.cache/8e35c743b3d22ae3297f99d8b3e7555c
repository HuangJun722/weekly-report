		<title>Veritas Secures $12M to Advance Non-Surgical Aortic Care</title>
		<link>https://ventureburn.com/veritas-secures-12m-to-advance-non-surgical-aortic-care/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Mon, 01 Jun 2026 16:30:23 +0000</pubDate>
