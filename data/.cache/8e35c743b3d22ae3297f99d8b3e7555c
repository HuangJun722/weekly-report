		<title>Ollama Raises $65M to Expand Open AI Developer Platform</title>
		<link>https://ventureburn.com/ollama-raises-65m-expand-open-ai-platform/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 09 Jul 2026 17:21:33 +0000</pubDate>
				<category><![CDATA[News]]></category>
