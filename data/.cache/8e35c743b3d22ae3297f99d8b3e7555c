		<title>Lassie Raises $35M to Expand Autonomous AI for Small Businesses</title>
		<link>https://ventureburn.com/lassie-raises-35m-ai-small-business-automation/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 04 Jun 2026 10:25:43 +0000</pubDate>
				<category><![CDATA[AI]]></category>
		<category><![CDATA[News]]></category>
		<category><![CDATA[Venture Capital]]></category>
