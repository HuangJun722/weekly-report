		<title>Xoople Raises $130M to Build Global System of Record for Physical Change</title>
		<link>https://ventureburn.com/xoople-raises-130m-to-build-global-system-of-record-for-physical-change/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
