		<title>Quobly Closes €115M Series A for Quantum Growth</title>
		<link>https://ventureburn.com/quobly-closes-e115m-series-a-for-quantum-growth/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Wed, 03 Jun 2026 16:45:57 +0000</pubDate>
