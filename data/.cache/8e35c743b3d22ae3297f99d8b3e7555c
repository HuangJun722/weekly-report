		<title>Sedron Technologies Raises $500M to Scale Waste-to-Resource Upcycling</title>
		<link>https://ventureburn.com/sedron-technologies-raises-500m-waste-upcycling/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 09 Apr 2026 17:41:38 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[Startup]]></category>
