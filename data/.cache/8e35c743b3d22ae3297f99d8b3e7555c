		<title>NVision Raises $55M to Expand Quantum Healthcare Tech</title>
		<link>https://ventureburn.com/nvision-raises-55m-to-expand-quantum-healthcare-tech/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Wed, 13 May 2026 16:13:28 +0000</pubDate>
				<category><![CDATA[News]]></category>
