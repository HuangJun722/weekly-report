		<title>Click Therapeutics Secures $50M Series D Funding Deal</title>
		<link>https://ventureburn.com/click-therapeutics-secures-50m-series-d-funding-deal/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Thu, 09 Apr 2026 18:08:02 +0000</pubDate>
