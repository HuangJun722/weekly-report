		<title>SiFive Raises $400 Million to Advance RISC-V Data Centre Chips</title>
		<link>https://ventureburn.com/sifive-raises-400m-data-centre/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 09 Apr 2026 16:55:52 +0000</pubDate>
				<category><![CDATA[News]]></category>
