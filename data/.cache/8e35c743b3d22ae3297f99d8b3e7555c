		<title>France Raises €13 Billion to Boost European Tech Investment</title>
		<link>https://ventureburn.com/france-raises-e13-billion-to-boost-european-tech-investment/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Fri, 19 Jun 2026 23:13:12 +0000</pubDate>
				<category><![CDATA[News]]></category>
		<category><![CDATA[Venture Capital]]></category>
