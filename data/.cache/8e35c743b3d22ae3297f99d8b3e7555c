		<title>Behavox Raises $175M to Expand AI-Native Compliance Platform</title>
		<link>https://ventureburn.com/behavox-raises-175m-ai-compliance-platform/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Wed, 17 Jun 2026 19:19:12 +0000</pubDate>
				<category><![CDATA[News]]></category>
