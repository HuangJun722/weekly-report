		<title>Hermeus Raises $350M to Accelerate Hypersonic Aircraft Development</title>
		<link>https://ventureburn.com/hermeus-raises-350m-to-accelerate-hypersonic-aircraft-development/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
