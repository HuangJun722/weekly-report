		<link>https://ventureburn.com/livid-raises-10m-to-build-an-ad-free-video-hosting-alternative/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 09 Apr 2026 00:49:58 +0000</pubDate>
