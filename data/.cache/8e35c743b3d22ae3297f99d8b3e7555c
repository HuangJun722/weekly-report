		<title>Collate Raises $95M to Transform Life Sciences AI</title>
		<link>https://ventureburn.com/collate-raises-95m-to-transform-life-sciences-ai/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Fri, 05 Jun 2026 13:00:15 +0000</pubDate>
