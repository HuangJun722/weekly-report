		<title>Synthetic Raises $10M Seed Funding For AI Bookkeeping Platform</title>
		<link>https://ventureburn.com/synthetic-raises-10m-seed-funding-for-ai-bookkeeping-platform/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 14 May 2026 13:40:20 +0000</pubDate>
				<category><![CDATA[AI]]></category>
		<category><![CDATA[News]]></category>
		<category><![CDATA[Venture Capital]]></category>
