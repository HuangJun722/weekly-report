		<title>Secretome Therapeutics Raises $30M Series A for Cardiac Cell Therapy Expansion</title>
		<link>https://ventureburn.com/secretome-raises-funding-series-a-stm01/</link>
		
		<dc:creator><![CDATA[Clinton]]></dc:creator>
		<pubDate>Thu, 28 May 2026 10:59:11 +0000</pubDate>
				<category><![CDATA[News]]></category>
