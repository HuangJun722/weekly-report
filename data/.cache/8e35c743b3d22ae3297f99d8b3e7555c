		<title>Twinco Secures €165M to Scale Trade Finance Model</title>
		<link>https://ventureburn.com/twinco-secures-e165m-to-scale-trade-finance-model/</link>
		
		<dc:creator><![CDATA[Ekemini]]></dc:creator>
		<pubDate>Tue, 02 Jun 2026 18:11:27 +0000</pubDate>
				<category><![CDATA[News]]></category>
