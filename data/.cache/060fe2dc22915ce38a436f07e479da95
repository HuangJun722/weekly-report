		<title>How extended reality and spatial computing will define 2026</title>
		<link>https://contxto.com/en/news/how-extended-reality-and-spatial-computing-will-define-2026/</link>
					<comments>https://contxto.com/en/news/how-extended-reality-and-spatial-computing-will-define-2026/#respond</comments>
		
		<dc:creator><![CDATA[Santiago Cardona]]></dc:creator>
		<pubDate>Wed, 04 Mar 2026 13:57:07 +0000</pubDate>
