		<link>https://contxto.com/en/central-america/the-startup-ecosystem-in-central-america-is-expanding-rapidly/</link>
					<comments>https://contxto.com/en/central-america/the-startup-ecosystem-in-central-america-is-expanding-rapidly/#respond</comments>
		
		<dc:creator><![CDATA[Israel Pantaleón]]></dc:creator>
