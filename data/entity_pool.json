{
  "version": "2026-06-08",
  "principles": [
    "对象池不是新闻源列表，而是长期观察对象资产。",
    "每个对象至少区分官方披露、招聘/组织动作、产品/API/开发者变更三类观察点。",
    "active 表示当前采集链路已有对应来源或公司监控；candidate 表示已进入治理池但尚未接入自动抓取。",
    "观察点需要像事件一样做转化监控：raw_signal -> candidate_signal -> qualified_signal -> event -> window。"
  ],
  "entity_schema": {
    "id": "稳定唯一标识",
    "name": "对象名称",
    "aliases": "事件匹配别名",
    "region": "主要观察区域",
    "sector": "主赛道",
    "priority": "core / watch",
    "observation_points": "该对象的长期观察点"
  },
  "observation_point_schema": {
    "type": "newsroom / ir / jobs / changelog / developer_docs / product_update",
    "url": "公开入口地址；未知或暂不稳定时可为空",
    "status": "active / candidate / paused",
    "instrumented": "是否已进入结构化转化统计",
    "expected_signals": "该观察点理论上产出的组织行为信号"
  },
  "conversion_schema": {
    "raw_signal": "观察点原始变化或抓取条目",
    "candidate_signal": "命中对象和信号类型的候选变化",
    "qualified_signal": "通过本站边界、质量和去重后的合格信号",
    "event": "进入 events.json 的结构化事件",
    "window": "在周报/关注窗口中形成跨事件解释"
  },
