{
  "permissions": {
    "allow": [
      "Edit(scripts/*.py)",
      "Write(scripts/*.py)",
      "Edit(.github/workflows/*.yml)",
      "Write(.github/workflows/*.yml)",
      "Edit(scripts/template.html)",
      "Write(scripts/template.html)",
      "Read",
      "Glob",
      "Grep",
      "Bash(python scripts/*.py)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(git push --force)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import ast; ast.parse(open('scripts/fetch_news.py', encoding='utf-8').read())\" 2>&1 || exit 1",
            "timeout": 15,
            "statusMessage": "语法检查..."
          },
          {
            "type": "command",
            "command": "python scripts/generate_html.py 2>&1",
            "timeout": 30,
            "statusMessage": "生成验证..."
          }
        ]
      }
    ]
  }
}
